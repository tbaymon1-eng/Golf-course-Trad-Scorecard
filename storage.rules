rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function userOrgId() {
      let u = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
      let a = u.orgId is string ? u.orgId : "";
      let b = u.organizationId is string ? u.organizationId : "";
      return a != "" ? a : b;
    }

    match /org-logos/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && orgId == userOrgId()
        && userOrgId() != ""
        && request.resource.size < 6 * 1024 * 1024
        && (request.resource.contentType == 'image/png'
            || request.resource.contentType == 'image/jpeg');
    }

    match /org-scorecards/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && orgId == userOrgId()
        && userOrgId() != ""
        && request.resource.size < 12 * 1024 * 1024
        && (request.resource.contentType == 'image/png'
            || request.resource.contentType == 'image/jpeg');
    }
  }
}
