rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isOrgMember(oid) {
      let p = firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
      let a = p.orgId is string ? p.orgId : "";
      let b = p.organizationId is string ? p.organizationId : "";
      let legacy = a != "" ? a : b;
      return request.auth != null
        && (
          (p.orgIds is list && oid in p.orgIds) ||
          (oid == legacy && legacy != "")
        );
    }

    match /org-logos/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && isOrgMember(orgId)
        && request.resource.size < 6 * 1024 * 1024
        && (request.resource.contentType == 'image/png'
            || request.resource.contentType == 'image/jpeg');
    }

    match /org-scorecards/{orgId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && isOrgMember(orgId)
        && request.resource.size < 12 * 1024 * 1024
        && (request.resource.contentType == 'image/png'
            || request.resource.contentType == 'image/jpeg');
    }
  }
}
